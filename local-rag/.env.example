# LLM model to use for chat (must be pulled via `ollama pull <model>`)
# Default: llama3.2:1b
CHAT_MODEL=llama3.2:1b

# Embedding model used to vectorize document chunks and queries (must be pulled via `ollama pull <model>`)
# Default: nomic-embed-text
EMBEDDING_MODEL=nomic-embed-text

# Base URL of the Ollama server
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434
